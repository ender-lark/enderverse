# Small Biz Website Builder — environment
# Copy to .env.local for dev. MOCK_MODE=true runs the whole app with fixtures (no spend).

MOCK_MODE=true

# Database (Supabase Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""        # server-only

# Google Maps Platform (Places API New + Geocoding) — server-only
GOOGLE_MAPS_API_KEY=""

# US Census ACS (free; 500 req/day without a key)
CENSUS_API_KEY=""

# Anthropic (Claude) — content + pitch generation, server-only
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"   # default; opus-4-8 for premium, haiku-4-5 for cheap regen

# Images
PEXELS_API_KEY=""                     # Pexels first (no attribution required)

# Auth gate for the 1-2 operators (simple shared password; or wire Supabase magic-link)
APP_PASSWORD="change-me"

# Cost guardrail (USD/month); scans abort past this
MONTHLY_SPEND_CAP_USD="50"
